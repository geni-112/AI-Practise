{
  "region": "la-south-2",
  "bucket": "docktest",
  "cluster": {
    "mode": "existing-or-transient",
    "existing_cluster_id_env": "MRS_CLUSTER_ID",
    "transient_cluster_name_prefix": "mrs-dockone-hudi-demo",
    "cluster_version": "MRS 3.5.0-LTS",
    "cluster_type": "ANALYSIS",
    "components": "Hadoop,Hive,Spark,JobGateway",
    "vpc_name": "vpc-cloudera-test",
    "subnet_id": "4bc25a96-2798-431e-adb4-abe34f6566f5",
    "subnet_name": "subnet-cloudera-test",
    "availability_zone": "la-south-2a",
    "security_groups_id": "0e302a4d-fe1c-42e5-a3ff-31c2a99b0a19",
    "mrs_ecs_default_agency": "dockone_mrs_ecs_agency",
    "master_node_size": "c6.4xlarge.4.linux.bigdata",
    "core_node_size": "c6.4xlarge.4.linux.bigdata",
    "master_node_num": 2,
    "core_node_num": 3,
    "root_volume_type": "SAS",
    "root_volume_size": 480,
    "data_volume_type": "SAS",
    "data_volume_size": 600,
    "data_volume_count": 1,
    "delete_when_no_steps": false
  },
  "spark": {
    "deploy_mode": "cluster",
    "master": "yarn",
    "hudi_bundle": "obs://${DEMO_BUCKET}/jobs/jars/hudi-spark3.3-bundle_2.12-0.15.0.jar",
    "job_properties": {
      "fs.obs.endpoint": "obs.la-south-2.myhuaweicloud.com"
    },
    "conf": {
      "spark.serializer": "org.apache.spark.serializer.KryoSerializer",
      "spark.sql.catalogImplementation": "hive",
      "spark.sql.shuffle.partitions": "2",
      "spark.sql.files.maxRecordsPerFile": "50000"
    }
  }
}
